# Environment Variables Configuration Example
# Copy this file to .env and adjust values for your environment

# ========================================
# Database Configuration (TimescaleDB)
# ========================================
DB_HOST=timescaledb
DB_PORT=5432
DB_NAME=cryptoterm
DB_USER=cryptoterm
DB_PASSWORD=cryptoterm

# ========================================
# MongoDB Configuration
# ========================================
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_DATABASE=cryptoterm
MONGODB_USERNAME=cryptoterm
MONGODB_PASSWORD=cryptoterm

# ========================================
# MQTT Configuration
# ========================================
MQTT_BROKER=tcp://mosquitto:1883
# Для SSL используйте: ssl://mosquitto:8883
MQTT_CLIENT_ID=cryptoterm-backend
MQTT_USERNAME=
MQTT_PASSWORD=

# MQTT SSL/TLS Configuration (опционально)
MQTT_SSL_ENABLED=false
MQTT_SSL_TRUST_STORE=/opt/cryptoterm/mqtt-truststore.jks
MQTT_SSL_TRUST_STORE_PASSWORD=changeit
# Для mutual TLS (опционально):
MQTT_SSL_KEY_STORE=/opt/cryptoterm/mqtt-keystore.jks
MQTT_SSL_KEY_STORE_PASSWORD=changeit

# ========================================
# JWT Configuration
# ========================================
# IMPORTANT: Change this in production!
# Generate secure key with: openssl rand -hex 32
JWT_SECRET=change-me-in-production-this-is-a-very-long-secure-secret-key-for-jwt-tokens
JWT_EXPIRATION_SECONDS=3600
JWT_REFRESH_EXPIRATION_SECONDS=648000

# ========================================
# Device Registration & ASIC Proxy Signature
# ========================================
# ВАЖНО: Этот ключ используется для:
# 1. Регистрации Raspberry Pi устройств (X-API-Key header)
# 2. HMAC подписи команд к ASIC майнерам
# Сгенерируйте безопасный ключ: openssl rand -base64 32
DEVICE_REGISTRATION_API_KEY=default-device-key-change-in-production

# ASIC Proxy Commands - HMAC Signature
ASIC_PROXY_SIGNATURE_ENABLED=false
# Примечание: ASIC_PROXY_SECRET автоматически использует DEVICE_REGISTRATION_API_KEY

# ========================================
# Server Configuration
# ========================================
SERVER_PORT=8080

# ========================================
# Backup Configuration
# ========================================
BACKUP_DIR=/var/backups/cryptoterm
RETENTION_DAYS=7
